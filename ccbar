#!/usr/bin/env bash
# ccbar — launcher for Claude Code status bar
#
# Usage:
#   ccbar [--path <claude-dir>] <command> [args...]
#   ccbar bar         Start top bar on current terminal
#   ccbar dashboard   Open dashboard in a new tab
#   ccbar reset [%]   Mark window start (with optional base usage %)
#   ccbar stop        Stop all ccbar processes for this surface
#   ccbar stop-all    Stop all ccbar processes

set -euo pipefail

# Resolve symlinks to find the real script directory
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# Parse --path option before command
CLAUDE_HOME="${CLAUDE_HOME:-$HOME/.claude}"
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --path)
      shift
      CLAUDE_HOME="${1:?'--path requires a directory argument'}"
      # Expand ~ if present
      CLAUDE_HOME="${CLAUDE_HOME/#\~/$HOME}"
      shift
      ;;
    *)
      echo "ccbar: unknown option $1" >&2; exit 1
      ;;
  esac
done

CMD="${1:-help}"
SURFACE="${CMUX_SURFACE_ID:-}"

# Derive CLAUDE_DIR from CLAUDE_HOME (projects subdirectory)
CLAUDE_DIR="${CLAUDE_DIR:-$CLAUDE_HOME/projects}"
export CLAUDE_DIR CLAUDE_HOME

# Ensure CLAUDE_PLAN is set (from env, or read from cmux, or default)
if [[ -z "${CLAUDE_PLAN:-}" ]]; then
  CLAUDE_PLAN=$(cmux display-message -p '#{CLAUDE_PLAN}' 2>/dev/null || true)
fi
CLAUDE_PLAN="${CLAUDE_PLAN:-pro}"
export CLAUDE_PLAN

case "$CMD" in
  bar)
    # Setup scroll region and start background updater in THIS terminal
    eval "$("$SCRIPT_DIR/ccbar-header.sh" setup)"
    CLAUDE_PLAN="$CLAUDE_PLAN" CLAUDE_DIR="$CLAUDE_DIR" CLAUDE_HOME="$CLAUDE_HOME" \
      CLAUDE_PROJECT="${CLAUDE_PROJECT:-$PWD}" \
      "$SCRIPT_DIR/ccbar-header.sh" update
    # Background loop — must write to the TTY, not /dev/null
    tty_dev=$(tty 2>/dev/null || echo /dev/tty)
    (
      while true; do
        sleep "${2:-10}"
        CLAUDE_PLAN="$CLAUDE_PLAN" CLAUDE_DIR="$CLAUDE_DIR" CLAUDE_HOME="$CLAUDE_HOME" \
          CLAUDE_PROJECT="${CLAUDE_PROJECT:-$PWD}" \
          "$SCRIPT_DIR/ccbar-header.sh" update
      done
    ) > "$tty_dev" 2>/dev/null &
    disown
    echo "ccbar: header started (refreshing every ${2:-10}s)"
    ;;

  dashboard|dash)
    project_path="$(cd "${CLAUDE_PROJECT:-$PWD}" 2>/dev/null && pwd || echo "$PWD")"

    if [[ -n "${CMUX_SURFACE_ID:-}" ]]; then
      # cmux: open in new tab
      result=$(cmux new-surface 2>&1)
      new_surface=$(echo "$result" | grep -oE 'surface:[0-9]+')
      if [[ -z "$new_surface" ]]; then
        echo "ccbar: failed to create tab: $result" >&2; exit 1
      fi
      cmux rename-tab --surface "$new_surface" "ccbar dashboard" 2>/dev/null || true
      cmux send --surface "$new_surface" "export CLAUDE_PLAN='${CLAUDE_PLAN}' CLAUDE_PROJECT='${project_path}' CLAUDE_DIR='${CLAUDE_DIR}' CLAUDE_HOME='${CLAUDE_HOME}' && '${SCRIPT_DIR}/ccbar-dashboard.sh' 10"$'\r' 2>/dev/null
      echo "ccbar: dashboard opened on $new_surface (plan=${CLAUDE_PLAN}, project=$(basename "$project_path"))"

    elif [[ -n "${TMUX:-}" ]]; then
      # tmux: open in new window
      tmux new-window -n "ccbar dashboard" \
        "CLAUDE_PLAN='${CLAUDE_PLAN}' CLAUDE_PROJECT='${project_path}' CLAUDE_DIR='${CLAUDE_DIR}' CLAUDE_HOME='${CLAUDE_HOME}' '${SCRIPT_DIR}/ccbar-dashboard.sh' 10"
      echo "ccbar: dashboard opened in new tmux window (plan=${CLAUDE_PLAN}, project=$(basename "$project_path"))"

    else
      # standalone: run in current terminal
      echo "ccbar: starting dashboard (plan=${CLAUDE_PLAN}, project=$(basename "$project_path"))"
      CLAUDE_PLAN="$CLAUDE_PLAN" CLAUDE_PROJECT="$project_path" CLAUDE_DIR="$CLAUDE_DIR" CLAUDE_HOME="$CLAUDE_HOME" \
        exec "$SCRIPT_DIR/ccbar-dashboard.sh" 10
    fi
    ;;

  stop)
    if [[ -n "$SURFACE" ]]; then
      pkill -f "ccbar.*${SURFACE}" 2>/dev/null && echo "ccbar: stopped for this surface" || echo "ccbar: nothing running"
    else
      killed=0
      pkill -f "ccbar-header.sh" 2>/dev/null && killed=1
      pkill -f "ccbar-dashboard.sh" 2>/dev/null && killed=1
      (( killed )) && echo "ccbar: stopped" || echo "ccbar: nothing running"
    fi
    ;;

  stop-all)
    pkill -f "ccbar-bar.sh\|ccbar-dashboard.sh\|ccbar-cmux.sh\|ccbar-panel.sh" 2>/dev/null && echo "ccbar: all stopped" || echo "ccbar: nothing running"
    ;;

  reset)
    # Manual window reset — saves current UTC timestamp and optional base usage %
    reset_file="$CLAUDE_HOME/ccbar_reset"
    base_pct="${2:-0}"
    mkdir -p "$CLAUDE_HOME"
    printf "%s\n%s" "$(date -u +"%Y-%m-%dT%H:%M:%S+00:00")" "$base_pct" > "$reset_file"
    if (( base_pct > 0 )); then
      echo "ccbar: window reset at $(head -1 "$reset_file") with ${base_pct}% base usage"
    else
      echo "ccbar: window reset at $(head -1 "$reset_file")"
    fi
    echo "ccbar: 5h window will now count from this moment"
    ;;

  reset-clear)
    # Remove manual reset
    rm -f "$CLAUDE_HOME/ccbar_reset"
    echo "ccbar: manual reset cleared, using auto-detection"
    ;;

  help|*)
    echo "Usage: ccbar [--path <claude-dir>] <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  bar          — top bar on current terminal"
    echo "  dashboard    — full dashboard in a new tab"
    echo "  reset [%]    — mark window start (optional base usage %)"
    echo "  reset-clear  — remove manual reset, use auto-detection"
    echo "  stop         — stop ccbar for this terminal"
    echo "  stop-all     — stop all ccbar processes"
    echo ""
    echo "Options:"
    echo "  --path DIR   — use DIR instead of ~/.claude (e.g. ~/.claude-pessoal)"
    ;;
esac
